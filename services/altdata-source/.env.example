# 环境配置示例，部署时拷贝为 .env
# 项目基础信息
PROJECT_NAME="altdata-source"
VERSION="1.0.0"
PORT=8011

# GitHub Token(s)，多个 token 用逗号分隔
GITHUB_TOKENS="ghp_token1,ghp_token2"

# 数据库配置 (后续使用)
CLICKHOUSE_HOST="127.0.0.1"
CLICKHOUSE_PORT=9000
CLICKHOUSE_USER="default"
CLICKHOUSE_PASSWORD=""
CLICKHOUSE_DB="altdata"

# 服务发现
NACOS_HOST="127.0.0.1"
NACOS_PORT=8848
NACOS_NAMESPACE="public"
