# TaskScheduler 服务配置

# 应用配置
APP_NAME=TaskScheduler
APP_VERSION=2.0.0
DEBUG=true
LOG_LEVEL=INFO

# 服务配置
HOST=0.0.0.0
PORT=8080
WORKERS=1

# 数据库配置 - 使用你现有的外部 MySQL
MYSQL_HOST=your-mysql-host
MYSQL_PORT=3306
MYSQL_DATABASE=microservice_stock
MYSQL_USER=your-username
MYSQL_PASSWORD=your-password

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ClickHouse 配置
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=default

# 安全配置
SECRET_KEY=dev-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30

# 调度器配置
SCHEDULER_TIMEZONE=Asia/Shanghai
MAX_WORKERS=10
JOB_DEFAULTS_COALESCE=true
JOB_DEFAULTS_MAX_INSTANCES=1

# 监控配置
ENABLE_METRICS=true
METRICS_PORT=9090

# 代理配置
HTTP_PROXY=http://192.168.151.18:3128
HTTPS_PROXY=http://192.168.151.18:3128

# 时区配置
TIMEZONE=Asia/Shanghai