# Data Collector 环境变量配置

# 服务配置
DC_DEBUG=true
DC_HOST=0.0.0.0
DC_PORT=8089

# Nacos
DC_NACOS_SERVER=nacos:8848
DC_NACOS_NAMESPACE=

# ClickHouse
DC_CLICKHOUSE_HOST=microservice-stock-clickhouse
DC_CLICKHOUSE_PORT=9000
DC_CLICKHOUSE_DATABASE=stock_data
DC_CLICKHOUSE_USER=default
DC_CLICKHOUSE_PASSWORD=

# 腾讯云 MySQL
DC_MYSQL_HOST=
DC_MYSQL_PORT=3306
DC_MYSQL_DATABASE=stock_data
DC_MYSQL_USER=
DC_MYSQL_PASSWORD=

# Redis
DC_REDIS_HOST=microservice-stock-redis
DC_REDIS_PORT=6379
DC_REDIS_PASSWORD=redis123

# 采集配置
DC_BATCH_SIZE=100
DC_MAX_WORKERS=5
DC_DATASOURCE_URL=mootdx-source:50051
