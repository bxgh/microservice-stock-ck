{
  "name": "task-scheduler-frontend",
  "version": "1.0.0",
  "description": "Task Scheduler 微服务前端应用 - 基于 Vue 3 + TypeScript + Element Plus",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "test:e2e": "cypress run",
    "test:e2e:dev": "cypress open",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix",
    "lint:check": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "type-check": "vue-tsc --noEmit",
    "prepare": "husky install"
  },
  "dependencies": {
    "vue": "^3.4.0",
    "vue-router": "^4.2.0",
    "pinia": "^2.1.0",
    "element-plus": "^2.4.0",
    "@element-plus/icons-vue": "^2.3.0",
    "axios": "^1.6.0",
    "echarts": "^5.4.0",
    "vue-echarts": "^6.6.0",
    "dayjs": "^1.11.0",
    "lodash-es": "^4.17.0",
    "nprogress": "^0.2.0",
    "js-cookie": "^3.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/lodash-es": "^4.17.0",
    "@types/nprogress": "^0.2.0",
    "@types/js-cookie": "^3.0.0",
    "@vitejs/plugin-vue": "^4.5.0",
    "@vue/tsconfig": "^0.4.0",
    "typescript": "^5.0.0",
    "vue-tsc": "^1.8.0",
    "vite": "^5.0.0",
    "vitest": "^1.0.0",
    "@vitest/ui": "^1.0.0",
    "@vue/test-utils": "^2.4.0",
    "jsdom": "^23.0.0",
    "cypress": "^13.0.0",
    "eslint": "^8.55.0",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "eslint-plugin-vue": "^9.19.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.0.0",
    "prettier": "^3.1.0",
    "husky": "^8.0.0",
    "lint-staged": "^15.2.0",
    "sass": "^1.69.0",
    "unplugin-auto-import": "^0.17.0",
    "unplugin-vue-components": "^0.25.0",
    "@types/estree": "^1.0.0"
  },
  "lint-staged": {
    "*.{js,ts,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,scss,md}": [
      "prettier --write"
    ]
  },
  "keywords": [
    "vue3",
    "typescript",
    "element-plus",
    "task-scheduler",
    "microservice",
    "frontend"
  ],
  "author": "Task Scheduler Frontend Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/task-scheduler-frontend.git"
  },
  "bugs": {
    "url": "https://github.com/your-org/task-scheduler-frontend/issues"
  },
  "homepage": "https://github.com/your-org/task-scheduler-frontend#readme"
}