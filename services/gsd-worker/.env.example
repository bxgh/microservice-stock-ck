# =============================================================================
# gsd-worker 环境配置示例
# =============================================================================
# 复制此文件为 .env 并根据实际环境修改配置

# -----------------------------------------------------------------------------
# 服务配置
# -----------------------------------------------------------------------------
SERVICE_NAME=gsd-worker
SERVICE_VERSION=1.0.0
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# MySQL 配置 (读取源数据)
# -----------------------------------------------------------------------------
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=stock_user
MYSQL_PASSWORD=stock_password
MYSQL_DATABASE=stock_data
MYSQL_POOL_SIZE=5
MYSQL_MAX_OVERFLOW=10

# -----------------------------------------------------------------------------
# ClickHouse 配置 (写入目标)
# -----------------------------------------------------------------------------
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=9000
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=stock_data
CLICKHOUSE_POOL_SIZE=5

# -----------------------------------------------------------------------------
# Redis 配置 (任务状态)
# -----------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=1
REDIS_POOL_SIZE=5

# -----------------------------------------------------------------------------
# 任务配置
# -----------------------------------------------------------------------------
# 批量大小
BATCH_SIZE=1000

# 并发数
MAX_CONCURRENT_TASKS=10

# 超时时间 (秒)
TASK_TIMEOUT=3600

# 重试配置
MAX_RETRIES=3
RETRY_DELAY=5

# -----------------------------------------------------------------------------
# 分片配置
# -----------------------------------------------------------------------------
# 默认分片数 (可通过命令行参数覆盖)
DEFAULT_SHARD_COUNT=4

# -----------------------------------------------------------------------------
# 数据质量配置
# -----------------------------------------------------------------------------
# 数据完整性检查阈值
MIN_RECORD_COUNT=100
MAX_MISSING_DAYS=5

# 数据一致性检查
ENABLE_CONSISTENCY_CHECK=true

# -----------------------------------------------------------------------------
# K线同步调度配置 (自适应调度器)
# -----------------------------------------------------------------------------
# 历史缓冲时间 (分钟) - 从历史完成时间提前多少分钟开始轮询
GSD_KLINE_SYNC_HISTORY_BUFFER_MIN=5

# 长休眠检查间隔 (分钟) - 等待期间定期检查的间隔
GSD_KLINE_SYNC_SLEEP_CHECK_INTERVAL_MIN=15

# 轮询频率 (分钟) - 进入窗口期后的检查频率
GSD_KLINE_SYNC_POLL_INTERVAL_MIN=2

# 超时时间 (HH:MM) - 超过此时间仍未完成视为超时
GSD_KLINE_SYNC_TIMEOUT_TIME=21:00

# 最小记录阈值 - 云端采集记录数低于此值触发告警
GSD_KLINE_SYNC_MIN_RECORDS=4800

# 批次大小 - 每批次从MySQL读取的记录数
GSD_KLINE_SYNC_BATCH_SIZE=10000
