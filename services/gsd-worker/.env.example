# =============================================================================
# gsd-worker 环境配置示例
# =============================================================================
# 复制此文件为 .env 并根据实际环境修改配置

# -----------------------------------------------------------------------------
# 服务配置
# -----------------------------------------------------------------------------
SERVICE_NAME=gsd-worker
SERVICE_VERSION=1.0.0
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# MySQL 配置 (读取源数据)
# -----------------------------------------------------------------------------
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=stock_user
MYSQL_PASSWORD=stock_password
MYSQL_DATABASE=stock_data
MYSQL_POOL_SIZE=5
MYSQL_MAX_OVERFLOW=10

# -----------------------------------------------------------------------------
# ClickHouse 配置 (写入目标)
# -----------------------------------------------------------------------------
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=9000
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=stock_data
CLICKHOUSE_POOL_SIZE=5

# -----------------------------------------------------------------------------
# Redis 配置 (任务状态)
# -----------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=1
REDIS_POOL_SIZE=5

# -----------------------------------------------------------------------------
# 任务配置
# -----------------------------------------------------------------------------
# 批量大小
BATCH_SIZE=1000

# 并发数
MAX_CONCURRENT_TASKS=10

# 超时时间 (秒)
TASK_TIMEOUT=3600

# 重试配置
MAX_RETRIES=3
RETRY_DELAY=5

# -----------------------------------------------------------------------------
# 分片配置
# -----------------------------------------------------------------------------
# 默认分片数 (可通过命令行参数覆盖)
DEFAULT_SHARD_COUNT=4

# -----------------------------------------------------------------------------
# 数据质量配置
# -----------------------------------------------------------------------------
# 数据完整性检查阈值
MIN_RECORD_COUNT=100
MAX_MISSING_DAYS=5

# 数据一致性检查
ENABLE_CONSISTENCY_CHECK=true
