# CCI Monitor Configuration Example

# App
CCI_ENV=dev
CCI_DEBUG=true
CCI_LOG_LEVEL=DEBUG

# Server
CCI_PORT=8085

# MySQL Database (Tencent Cloud via Tunnel)
CCI_DB_HOST=127.0.0.1
CCI_DB_PORT=36301
CCI_DB_USER=root
CCI_DB_PASSWORD=alwaysup@888
CCI_DB_NAME=alwaysup

# Data API
CCI_GSD_API_URL=http://127.0.0.1:8000

# Nacos
CCI_NACOS_SERVER_URL=http://127.0.0.1:8848
CCI_ENABLE_NACOS=false
