# TaskScheduler 服务配置

# 应用配置
APP_NAME=TaskScheduler
APP_VERSION=2.0.0
DEBUG=false
LOG_LEVEL=INFO

# 服务配置
HOST=0.0.0.0
PORT=8080
WORKERS=1

# 服务注册发现配置
REGISTRY_TYPE=simple  # 可选: consul, nacos, simple
CONSUL_URL=http://localhost:8500
NACOS_URL=http://localhost:8848
SIMPLE_REGISTRY_URL=http://localhost:8501
REGISTRY_ENABLED=true
SERVICE_NAME=task-scheduler
SERVICE_TAGS=task-scheduler,v2.0.0,microservice-stock
ENVIRONMENT=development

# 数据库配置
MYSQL_HOST=your-mysql-host
MYSQL_PORT=3306
MYSQL_DATABASE=microservice_stock
MYSQL_USER=your-username
MYSQL_PASSWORD=your-password

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ClickHouse Connection (Updated for admin credentials)
CLICKHOUSE_HOST=microservice-stock-clickhouse
CLICKHOUSE_PORT=9000
CLICKHOUSE_DB=stock_data
CLICKHOUSE_USER=admin
CLICKHOUSE_PASSWORD=admin123
CLICKHOUSE_DATABASE=default

# 安全配置
SECRET_KEY=your-super-secret-key-change-this-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30

# 调度器配置
SCHEDULER_TIMEZONE=Asia/Shanghai
MAX_WORKERS=10
JOB_DEFAULTS_COALESCE=true
JOB_DEFAULTS_MAX_INSTANCES=1

# 监控配置
ENABLE_METRICS=true
METRICS_PORT=9090

# 代理配置
HTTP_PROXY=http://192.168.151.18:3128
HTTPS_PROXY=http://192.168.151.18:3128

# 时区配置
TIMEZONE=Asia/Shanghai