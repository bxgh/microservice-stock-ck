# =============================================================================
# gsd-api 环境配置示例
# =============================================================================
# 复制此文件为 .env 并根据实际环境修改配置

# -----------------------------------------------------------------------------
# 服务配置
# -----------------------------------------------------------------------------
SERVICE_NAME=gsd-api
SERVICE_VERSION=1.0.0
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8000

# -----------------------------------------------------------------------------
# MySQL 配置 (只读)
# -----------------------------------------------------------------------------
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=stock_user
MYSQL_PASSWORD=stock_password
MYSQL_DATABASE=stock_data
MYSQL_POOL_SIZE=10
MYSQL_MAX_OVERFLOW=20

# -----------------------------------------------------------------------------
# ClickHouse 配置 (只读)
# -----------------------------------------------------------------------------
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=9000
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=stock_data
CLICKHOUSE_POOL_SIZE=10

# -----------------------------------------------------------------------------
# Redis 配置 (缓存)
# -----------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_POOL_SIZE=10

# 缓存过期时间 (秒)
CACHE_TTL_REALTIME=5        # 实时数据 5秒
CACHE_TTL_DAILY=3600        # 日线数据 1小时
CACHE_TTL_FINANCIAL=86400   # 财务数据 1天

# -----------------------------------------------------------------------------
# Mootdx 配置 (实时行情)
# -----------------------------------------------------------------------------
MOOTDX_TIMEOUT=10
MOOTDX_RETRY_TIMES=3

# -----------------------------------------------------------------------------
# Nacos 配置 (可选)
# -----------------------------------------------------------------------------
NACOS_SERVER_ADDR=nacos:8848
NACOS_NAMESPACE=public
NACOS_GROUP=DEFAULT_GROUP
ENABLE_NACOS=false

# -----------------------------------------------------------------------------
# 性能配置
# -----------------------------------------------------------------------------
MAX_WORKERS=4
REQUEST_TIMEOUT=30
MAX_CONNECTIONS=100
