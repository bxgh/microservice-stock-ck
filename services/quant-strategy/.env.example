# Quant Strategy 服务配置

# 应用配置
QS_NAME=QuantStrategyService
QS_VERSION=1.0.0
QS_DEBUG=false
QS_LOG_LEVEL=INFO

# 服务配置
QS_HOST=0.0.0.0
QS_PORT=8084
QS_WORKERS=1

# 服务注册发现配置
NACOS_SERVER_URL=http://nacos:8848
SERVICE_NAME=quant-strategy
SERVICE_GROUP=DEFAULT_GROUP
SERVICE_PORT=8084
ENVIRONMENT=development

# Redis 配置
QS_REDIS_URL=redis://redis:6379
QS_REDIS_MAX_CONNECTIONS=20

# MySQL 数据库配置 (必填)
# ⚠️ 重要：必须在 .env 文件或环境变量中设置以下值
# ⚠️ 绝对不要在 docker-compose.yml 中硬编码数据库密码
QS_DATABASE_TYPE=mysql
QS_DB_HOST=your-database-host.com
QS_DB_PORT=3306
QS_DB_NAME=alwaysup
QS_DB_USER=your_username
QS_DB_PASSWORD=your_secure_password

# 数据源配置
QS_STOCKDATA_SERVICE_URL=http://get-stockdata:8080

# 策略引擎配置
QS_MAX_CONCURRENT_STRATEGIES=20
QS_SIGNAL_WINDOW_SECONDS=60
QS_BACKTEST_ENABLED=true

# 安全配置
# QS_API_KEY=your-api-key-here

# 监控配置
QS_MONITORING_ENABLED=true
QS_METRICS_PATH=/api/v1/metrics
QS_HEALTH_CHECK_INTERVAL=30

# 代理配置
HTTP_PROXY=http://192.168.151.18:3128
HTTPS_PROXY=http://192.168.151.18:3128

# 时区配置
QS_TIMEZONE=Asia/Shanghai
